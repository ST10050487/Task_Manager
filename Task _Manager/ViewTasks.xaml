<Window x:Class="Task__Manager.ViewTasks"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Tasks" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <!-- Modern Button Style for the Close Button -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4338CA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- For the Title -->
            <RowDefinition Height="*"/>
            <!-- Takes remaining space for the list -->
            <RowDefinition Height="Auto"/>
            <!-- For the Close Button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="My Tasks" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

        <!-- Task List -->
        <ListView x:Name="TasksListView" Grid.Row="1" BorderThickness="0" Background="Transparent" 
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <!-- Remove default blue hover highlight from ListView -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <!-- Blueprint for how EVERY task should look -->
            <ListView.ItemTemplate>
                <DataTemplate>
                    <!-- White Card Container -->
                    <Border Background="White" CornerRadius="10" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.05" Color="Black"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Checkbox -->
                                <ColumnDefinition Width="*"/>
                                <!-- Text details -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Due Date -->
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox (Bound to IsCompleted) -->
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}" IsEnabled="False" VerticalAlignment="Center" Margin="0,0,20,0">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="1.3" ScaleY="1.3"/>
                                </CheckBox.LayoutTransform>
                            </CheckBox>

                            <!-- Task Details (Bound to Title and Description) -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Description}" FontSize="14" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- Due Date (Bound to DueDate and formatted to exclude time) -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <TextBlock Text="Due Date" FontSize="12" Foreground="#9CA3AF" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DueDate, StringFormat=d}" FontSize="15" FontWeight="Medium" Foreground="#374151" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer / Close Button -->
        <Button Grid.Row="2" Content="Close Window" Width="140" HorizontalAlignment="Right" Margin="0,20,0,0" 
                Style="{StaticResource ModernPrimaryButton}" Click="CloseButton_Click"/>
    </Grid>
</Window>