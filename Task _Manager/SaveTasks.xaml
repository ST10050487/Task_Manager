<Window x:Class="Task__Manager.SaveTasks"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Task" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <!-- Modern Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4338CA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Secondary (Cancel) Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                                <Setter Property="Foreground" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base Text Block Style for Labels -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Card Container -->
        <Border Background="White" CornerRadius="12" Margin="30" Padding="25"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05" Color="Black"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="New Task" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>
                <Separator Background="#E5E7EB" Margin="0,0,0,10"/>

                <!-- Title Input -->
                <TextBlock Text="Title" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="TitleTextBox" Padding="8" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1" TextChanged="TitleTextBox_TextChanged"/>

                <!-- Description Input -->
                <TextBlock Text="Description" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="DescriptionTextBox" Padding="8" FontSize="14" BorderBrush="#D1D5DB" BorderThickness="1" 
                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <!-- Due Date Input -->
                <TextBlock Text="Due Date" Style="{StaticResource InputLabel}"/>
                <DatePicker x:Name="DueDatePicker" SelectedDateChanged="DueDatePicker_SelectedDateChanged" Padding="5" FontSize="14" BorderBrush="#D1D5DB"/>

                <!-- Completed Checkbox -->
                <CheckBox x:Name="IsCompletedCheckBox" Content="Mark as completed" 
                          Foreground="#374151" FontSize="14" Margin="0,20,0,0" Cursor="Hand"/>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                    <Button Content="Cancel" Style="{StaticResource ModernSecondaryButton}" Margin="0,0,10,0" Click="CancelButton_Click" Background="Yellow"/>
                    <Button Content="Save Task" Style="{StaticResource ModernPrimaryButton}" Click="SaveButton_Click" Background="Green"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <Label x:Name="titleErrorlabel" Content="" HorizontalAlignment="Left" Margin="58,100,0,0" VerticalAlignment="Top" Height="23"/>
        <Label x:Name="dueDateErrorlabel" Content="" HorizontalAlignment="Left" Margin="58,295,0,0" VerticalAlignment="Top" Height="31"/>
    </Grid>
</Window>