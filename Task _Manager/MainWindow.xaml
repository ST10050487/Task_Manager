<Window x:Class="Task__Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Manager" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <!-- Define Modern Styles -->
    <Window.Resources>
        <!-- Primary Button Style -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4338CA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3730A3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="ModernSecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernPrimaryButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="450">
            <!-- Icon/Emoji Placeholder -->
            <TextBlock Text="📋" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <!-- Welcome Header -->
            <TextBlock Text="Welcome to Task Manager" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#111827" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <!-- Subtitle -->
            <TextBlock Text="Stay organized and manage your daily tasks efficiently. What would you like to do today?" 
                       FontSize="14" 
                       Foreground="#6B7280" 
                       TextWrapping="Wrap" 
                       TextAlignment="Center"
                       Margin="0,0,0,35"/>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Create New Task" 
                        Style="{StaticResource ModernPrimaryButton}" 
                        Width="160"
                        Margin="0,0,15,0"
                        Click="CreateTaskButton_Click"/>

                <Button Content="View Tasks" 
                        Style="{StaticResource ModernSecondaryButton}" 
                        Width="160"
                        Click="ViewTasksButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>